# --- Generation provider -------------------------------------------------------
# "local"  -> Ollama on this machine (default, no AWS / no hosted API)
# "bedrock"-> Amazon Bedrock (Part 2)
LLM_PROVIDER=local

# Local / Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=180
GENERATION_MAX_TOKENS=1024
GENERATION_TEMPERATURE=0.1

# --- Embeddings (always local, fastembed ONNX) ---------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Vector store --------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_data
COLLECTION_NAME=crm_docs

# --- Dataset -------------------------------------------------------------------
DATASET_DIR=./crm_rag_assistance

# --- Chunking & retrieval ------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=12
FINAL_TOP_K=6
ENTITY_TOP_K=8

# --- Guardrails (optional) -----------------------------------------------------
# API_KEY=set-an-owner-key-to-bypass-rate-limits
FREE_QUERIES_PER_DAY=50
GLOBAL_DAILY_CAP=1000

# --- Bedrock mode (Part 2) -----------------------------------------------------
# To use Bedrock: set LLM_PROVIDER=bedrock above and fill in the four lines below.
# Embeddings stay LOCAL, so you do NOT re-index when switching modes.
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
#
# AWS credentials for the limited IAM user (keep secret; .env is git-ignored):
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
